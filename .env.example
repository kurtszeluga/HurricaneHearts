# Browser app
# Leave this blank when the app and API are served from the same host.
VITE_EMAIL_API_URL=/api/send-email

# Serverless email API
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Hurricane Hearts <notifications@hurricanehearts.org>
RESEND_DRY_RUN=true

# Firebase Admin credentials for the serverless API.
# Recommended for Vercel/Netlify/Render: paste the full service account JSON.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"hurricane-hearts"}

# Optional CORS lock-down if the API is hosted on a different origin.
EMAIL_API_ALLOWED_ORIGIN=https://your-app-domain.example
